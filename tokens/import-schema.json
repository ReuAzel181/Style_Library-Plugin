{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design System Variable Import Schema",
  "type": "object",
  "properties": {
    "colors": {
      "type": "object",
      "properties": {
        "brand": { "type": "string", "description": "Hex code for the primary brand color" },
        "neutral": { "type": "string", "description": "Hex code for the base neutral color" },
        "white": { "type": "string" },
        "black": { "type": "string" }
      }
    },
    "typography": {
      "type": "object",
      "properties": {
        "fontFamily": { "type": "string" },
        "baseFontSize": { "type": "string", "default": "16px" }
      }
    },
    "spacing": {
      "type": "object",
      "properties": {
        "baseUnit": { "type": "number", "description": "The base unit for the 8px grid system", "default": 8 }
      }
    },
    "overrides": {
      "type": "object",
      "description": "Direct overrides for specific component tokens",
      "properties": {
        "button": { "type": "object" },
        "input": { "type": "object" }
      }
    }
  }
}
